# Copy to .env and fill in values — never commit .env

DB_ROOT_PASSWORD=StrongRootPassword123!
DB_USER=crout_user
DB_PASSWORD=StrongUserPassword123!

JWT_SECRET=your-256-bit-secret-key-change-me
JWT_ISSUER=crout-automations-api
JWT_AUDIENCE=crout-automations-client
JWT_EXPIRY_HOURS=8

HMAC_SECRET=crout-automations-secret-2026

# Comma-separated list of allowed CORS origins.
# REQUIRED in production — the API will return no CORS headers and
# all browser requests will be blocked if this is missing or empty.
# Example: https://automations.crout-holdings.com,https://crout-holdings.com
ALLOWED_ORIGINS=https://automations.crout-holdings.com,https://crout-holdings.com

SMTP_HOST=mail.mailer.com
SMTP_PORT=465
SMTP_ENABLE_SSL=true
SMTP_USERNAME=no_reply@crout-holdings.com
SMTP_PASSWORD=pwd

CONTACT_TO_EMAIL=info@crout-holdings.com
SMTP_FROM_EMAIL=no_reply@crout-holdings.com